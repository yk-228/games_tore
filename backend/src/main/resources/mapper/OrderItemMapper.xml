<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.gamestore.dao.OrderItemMapper">
    <insert id="insertBatch">
        INSERT INTO t_order_item(order_id, game_id, price, quantity)
        VALUES
        <foreach collection="items" item="item" separator=",">
            (#{item.orderId}, #{item.gameId}, #{item.price}, #{item.quantity})
        </foreach>
    </insert>
</mapper>
